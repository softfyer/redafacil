service firebase.storage {
  match /b/{bucket}/o {
    
    // Verifica se existe um documento na colunção 'teachers' 
    // onde o ID do documento é igual ao UID de quem está logado
    function isTeacher() {
      return firestore.exists(/databases/(default)/documents/teachers/$(request.auth.uid));
    }

    // Regras para a pasta de redações (essays)
    match /essays/{studentUid}/{allPaths=**} {
      
      // LEITURA E ESCRITA:
      // 1. Permite se for um professor (verificado no Firestore)
      // 2. OU permite se o UID da pasta for igual ao UID do aluno logado
      allow read, write: if request.auth != null && (
        isTeacher() || 
        request.auth.uid == studentUid
      );
    }
  }
}