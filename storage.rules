rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if a user is a teacher
    function isTeacher() {
      return exists(/databases/(default)/documents/teachers/$(request.auth.uid));
    }

    // Rules for all files under the 'essays' folder
    match /essays/{studentId}/{allPaths=**} {
      // Students can read and write to their own folder
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      
      // Teachers can write (upload/update) corrections to any student's folder,
      // but they cannot delete files.
      allow write: if request.auth != null && isTeacher();
    }
  }
}
